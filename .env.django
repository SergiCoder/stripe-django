# .env.django — committed, non-secret Django-specific config
# Secrets go in .env.dev / .env.prod
# Override DJANGO_SETTINGS_MODULE in .env.local for development (→ config.settings.dev)
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=["localhost","127.0.0.1"]
DJANGO_PORT=8001
DJANGO_STATIC_ROOT=/app/staticfiles
# browsable DRF API via Django session — enable only in .env.local for development
ENABLE_SESSION_AUTH=false
